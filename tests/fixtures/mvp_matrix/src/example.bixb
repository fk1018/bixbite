def add(x: Int, y: Int) -> Int
  x + y
end

def greet(name: Str, loud: Bool = false) -> Str
  loud ? name.upcase : name
end

def self.encode(id: Int, data: Str = "00") -> Str
  "#{id}:#{data}"
end

def ok?() -> TrueClass
  true
end

def set_name=(name: Str) -> Str
  @name = name
end

def   spaced(name  :   Str, count:Int = 1)   ->   Str
  name * count
end
